MONGO_URI=mongodb://localhost:27017/janata_portal
JWT_SECRET=your_secret_key_here
PORT=5000

# SMTP (required for email-based 2FA and password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAILER_LOG_ONLY=false

# Disable 2FA for local development only
DISABLE_2FA=false

# Optional password reset configuration (defaults shown)
PASSWORD_RESET_CODE_TTL_MS=900000
PASSWORD_RESET_RESEND_COOLDOWN_MS=30000
PASSWORD_RESET_MAX_ATTEMPTS=5

# Google OAuth (server)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
CLIENT_URL=http://localhost:3000
