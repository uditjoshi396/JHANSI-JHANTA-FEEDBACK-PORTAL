# ============================================
# JHANSI JANTA FEEDBACK PORTAL - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# --------------------------------------------
# SERVER CONFIGURATION
# --------------------------------------------
NODE_ENV=production
PORT=10000

# --------------------------------------------
# DATABASE (MongoDB Atlas)
# --------------------------------------------
# Get your connection string from MongoDB Atlas:
# https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=

# --------------------------------------------
# SECURITY
# --------------------------------------------
# Generate strong secrets (e.g., using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=
SESSION_SECRET=

# --------------------------------------------
# CORS / CLIENT URL
# --------------------------------------------
# Your deployed frontend URL (Vercel)
CLIENT_URL=https://your-vercel-app.vercel.app

# Your deployed backend URL (Render)
SERVER_BASE_URL=https://jhansi-janta-backend.onrender.com

# --------------------------------------------
# EMAIL (SMTP)
# --------------------------------------------
# Optional: configure for password reset & account emails
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Set to true to log emails instead of sending (useful for testing)
MAILER_LOG_ONLY=false

# --------------------------------------------
# GOOGLE OAUTH 2.0
# --------------------------------------------
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://jhansi-janta-backend.onrender.com/api/auth/google/callback

# --------------------------------------------
# FACEBOOK OAUTH
# --------------------------------------------
# Get credentials from: https://developers.facebook.com/apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://jhansi-janta-backend.onrender.com/api/auth/facebook/callback

# --------------------------------------------
# TWITTER OAUTH
# --------------------------------------------
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_CALLBACK_URL=https://jhansi-janta-backend.onrender.com/api/auth/twitter/callback

# --------------------------------------------
# INSTAGRAM OAUTH
# --------------------------------------------
# Get credentials from: https://developers.facebook.com/apps
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=https://jhansi-janta-backend.onrender.com/api/auth/instagram/callback

# --------------------------------------------
# OPTIONAL: ADMIN SEEDING
# --------------------------------------------
# Set to true on first deploy to create default admin account
# SEED_ADMIN=true
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=ChangeMe123!

